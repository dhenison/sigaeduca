# SIGA EDUCA — variáveis de ambiente (exemplo)
# Copie para .env.local e preencha. Nunca commit valores reais.

# Público (pode ir ao frontend — NÃO é autorização suficiente)
# Projeto: digjzihjboflcuftmokj (sigaeduca)
NEXT_PUBLIC_SUPABASE_URL=https://digjzihjboflcuftmokj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Somente servidor / Edge Functions / CI — NUNCA no frontend nem no Vercel como NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
SIGA_APP_ENV=development
SIGA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Vercel (quando houver build)
# Configure no painel do Vercel; não coloque service role em variáveis públicas.

# Config local do front estático: copie js/siga-config.example.js → js/siga-config.local.js
# (siga-config.local.js está no .gitignore)
